# Copy to .env and fill in values before running docker compose up

# ── MCP server — OpenEMR OAuth2 client ────────────────────────────────────────
# Register a client first:
#   curl -X POST https://<host>/oauth2/default/registration \
#     -H 'Content-Type: application/json' \
#     -d '{"client_name":"openemr-mcp",
#          "redirect_uris":["https://client.example.com/cb"],
#          "scope":"openid api:oemr user/Patient.read user/Appointment.read user/Appointment.write"}'
OPENEMR_CLIENT_ID=your-client-id
OPENEMR_CLIENT_SECRET=your-client-secret

# OpenEMR service account used by the MCP server (defaults to admin/pass)
OPENEMR_MCP_USER=admin
OPENEMR_MCP_PASS=pass

# ── Optional: insurance verification via Stedi ────────────────────────────────
STEDI_API_KEY=
STEDI_ENDPOINT=

# ── Optional: persistence backends ───────────────────────────────────────────
# Without these, waitlist and preference tools return 412 precondition_failed.
WAITLIST_BACKEND_URL=
PREFERENCES_BACKEND_URL=

# ── Optional: clinic configuration ───────────────────────────────────────────
# JSON inline; set to override the defaults shown below.
# OFFICE_HOURS_JSON=[{"day":"monday","open":"09:00","close":"17:00","closed":false},...]
# BILLING_POLICY_JSON={"insurance":"We accept most major insurance plans.","copay":"$20 copay at time of service."}
OFFICE_HOURS_JSON=
BILLING_POLICY_JSON=
