# Copy to .env and fill in your values
OPENEMR_BASE_URL=https://localhost:9300
OPENEMR_CLIENT_ID=your-client-id
OPENEMR_CLIENT_SECRET=your-client-secret
OPENEMR_USERNAME=admin
OPENEMR_PASSWORD=pass
OPENEMR_SITE=default

# Slot availability source for health_check_slots.
# auto        — try FHIR Slot first, fall back to Phase 1 REST (/api/provider/:id/schedule),
#               then fall back to algorithmic 08:00–17:00 generation.  (default)
# fhir        — use FHIR Schedule + Slot endpoints only; fail if unavailable.
# rest        — use Phase 1 REST endpoint only; fall back to algorithmic if no blocks found.
# algorithmic — always use hardcoded 08:00–17:00 generation (legacy behaviour).
OPENEMR_SCHEDULE_API=auto
